# ─── Application ──────────────────────────────────────
APP_NAME=Vanguard OSINT
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_generate_with_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=vanguard
POSTGRES_PASSWORD=CHANGE_THIS_strong_password
POSTGRES_DB=vanguard_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vanguard:CHANGE_THIS_strong_password@localhost:5432/vanguard_db

# ─── Neo4j ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_THIS_neo4j_password

# ─── Evidence Vault ───────────────────────────────────
# Local path where raw artifacts are stored
EVIDENCE_VAULT_PATH=./evidence
# Max file size for uploads (bytes) — default 50MB
MAX_UPLOAD_BYTES=52428800

# ─── JWT Auth ─────────────────────────────────────────
JWT_ALGORITHM=HS256
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Analysis Settings ────────────────────────────────
# Minimum tokens required for a stylometry comparison
STYLO_MIN_TOKENS=100
# Similarity threshold to flag as HIGH match
STYLO_HIGH_THRESHOLD=0.80
# Similarity threshold to flag as MEDIUM match
STYLO_MED_THRESHOLD=0.60
